graph TB
    subgraph Lifecycle["生命周期感知"]
        Activity["Activity/Fragment"]
        FM["SupportFragmentManager"]
        FR["RequestManagerFragment<br/>无 UI Fragment"]
        RM["RequestManager"]
        Target["Target<Drawable>"]
    end

    Activity -->|"getSupportFragmentManager"| FM
    FM -->|"findFragmentByTag"| FR
